# sdkconfig.opts — place this file in your Arduino sketch folder.
# The ESP32 Arduino core reads it at compile time and merges these
# settings into the build, enabling hardware bignum acceleration.
#
# MBEDTLS_HARDWARE_MPI
# ────────────────────
# Enables the ESP32 RSA/MPI hardware peripheral for bignum operations.
# This accelerates mbedTLS scalar multiplications (the bottleneck in
# EC-ElGamal) by ~3-5x by offloading modular exponentiation to hardware.
# No code changes needed — mbedTLS uses it automatically.
#
# MBEDTLS_HARDWARE_AES / SHA
# ──────────────────────────
# Enabled by default in the Arduino core but listed here for completeness.

CONFIG_MBEDTLS_HARDWARE_MPI=y
CONFIG_MBEDTLS_HARDWARE_AES=y
CONFIG_MBEDTLS_HARDWARE_SHA=y

# Increase MPI window size for faster scalar multiplication.
CONFIG_MBEDTLS_MPI_WINDOW_SIZE=8
CONFIG_MBEDTLS_MPI_MAX_SIZE=64

# NIST-curve fast-path arithmetic — only applies to SECP{192,224,256,384,521}R1.
# Cuts modular reduction time significantly on these curves.
CONFIG_MBEDTLS_ECP_NIST_OPTIM=y

# Precomputed table for the base-point G (speeds up encryption).
CONFIG_MBEDTLS_ECP_FIXED_POINT_OPTIM=y

# We don't need restartable EC ops — remove their overhead.
CONFIG_MBEDTLS_ECP_RESTARTABLE=n
